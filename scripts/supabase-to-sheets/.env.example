# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id
# Google 서비스 계정 JSON 키를 한 줄로 직렬화한 값
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"..."}

# 동기화 모드 (overwrite | append) — 단일/다중 모드 공통
SYNC_MODE=overwrite

# ── 단일 테이블 모드 (SYNC_TARGETS 없을 때 사용) ──────────────────────────────
TABLE_NAME=orders
# 쉼표로 구분 (비워두면 전체 컬럼)
COLUMNS=id,name,email,created_at
SHEET_NAME=Sheet1

# ── 다중 테이블 모드 (SYNC_TARGETS 있으면 단일 모드 무시) ──────────────────────
# 형식: "테이블명:시트탭명" 쌍을 쉼표로 구분
# SYNC_TARGETS=orders:orders,saved_sentences:saved_sentences,users:users

# 각 테이블별 컬럼 — COLUMNS_<TABLE_NAME_대문자> 형식
# 해당 변수가 없으면 SELECT * (전체 컬럼)
# COLUMNS_ORDERS=order_number,recipient_name,recipient_phone,total_amount,item_price,shipping_fee,postal_code,address,address_detail,delivery_message,payment_due_at,created_at
# COLUMNS_SAVED_SENTENCES=note,content_index,created_at
# COLUMNS_USERS=name,kakao_name,trace,wants_to_see_others,survey_answered_at,created_at
